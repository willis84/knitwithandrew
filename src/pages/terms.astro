---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { absoluteUrl } from "@/utils/seo";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Terms of Use",
  description: "Terms of use for Knit with Andrew, including information-only content, as-is use, and third-party links.",
  url: absoluteUrl("/terms/"),
};
---

<BaseLayout title="Terms of Use — Knit with Andrew" description="Terms of use for Knit with Andrew, including information-only content, as-is use, and third-party links." structuredData={structuredData}>
  <section class="mx-auto max-w-4xl px-5 py-12">
    <p class="text-sm font-black uppercase tracking-[0.25em] text-candy-paint">Terms</p>
    <h1 class="mt-4 text-6xl font-black tracking-tight text-ink">Terms of use</h1>
    <p class="mt-5 max-w-3xl text-xl font-semibold leading-8 text-ink-soft">
      These terms explain the basic rules for using this site and the limits on what the content is intended to do.
    </p>

    <div class="prose-kwa mt-12 rounded-4xl border-2 border-ink bg-paper/75 p-6 shadow-[10px_10px_0_rgba(16,16,20,0.14)] sm:p-8">
      <h2>Information Only</h2>
      <p>
        The blog posts, guides, pattern testing notes, and other content on this site are provided for general information only.
      </p>
      <p>
        Nothing on this site is professional, legal, medical, financial, or other regulated advice, and you are responsible for how you use the information.
      </p>

      <h2>As Is</h2>
      <p>
        This site and its content are provided on an as-is and as-available basis, without warranties, representations, or guarantees of any kind.
      </p>
      <p>
        I do not promise that the site will always be available, error-free, complete, or suitable for any particular purpose.
      </p>

      <h2>Liability</h2>
      <p>
        To the fullest extent allowed by law, I am not liable for any loss, damage, cost, or claim arising from your use of this site, your reliance on its content, or your use of any third-party services linked from it.
      </p>

      <h2>Third-Party Links</h2>
      <p>
        This site includes links to third-party websites and services such as Instagram, TikTok, Ravelry, Ko-fi, and Buttondown. I am not responsible for the content, availability, or terms of those third-party services.
      </p>

      <h2>Changes</h2>
      <p>
        I may update, remove, or change content on this site, and I may update these terms if the way the site operates changes.
      </p>
    </div>
  </section>
</BaseLayout>