---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found — Knit with Andrew" description="That page could not be found. Try the blog, guides, or homepage instead." noindex={true}>
  <section class="mx-auto max-w-4xl px-5 py-20 text-center">
    <p class="text-sm font-black uppercase tracking-[0.25em] text-voltage-inverse">404</p>
    <h1 class="mt-4 text-6xl font-black tracking-tight text-ink">Page not found</h1>
    <p class="mx-auto mt-5 max-w-2xl text-xl font-semibold leading-8 text-ink-soft">That page has wandered off. The blog, guides, and homepage are a better bet.</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/" class="rounded-full bg-panel px-6 py-3 text-sm font-black text-panel-text">Back home</a>
      <a href="/blog/" class="rounded-full border-2 border-ink bg-paper/70 px-6 py-3 text-sm font-black text-ink">Go to the blog</a>
    </div>
  </section>
</BaseLayout>
