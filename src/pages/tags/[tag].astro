---
import { getCollection } from "astro:content";
import PostCard from "@/components/PostCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { absoluteUrl } from "@/utils/seo";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter((post) => !post.data.draft);
  const tags = [...new Set(posts.flatMap((post) => post.data.tags))];

  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts.filter((post) => post.data.tags.includes(tag)),
    },
  }));
}

const { tag, posts } = Astro.props;
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: `#${tag}`,
    description: `Posts tagged ${tag} on Knit with Andrew.`,
    url: absoluteUrl(`/tags/${tag}/`),
    mainEntity: {
      "@type": "ItemList",
      itemListElement: posts.map((post: any, index: number) => ({
        "@type": "ListItem",
        position: index + 1,
        url: absoluteUrl(`/blog/${post.id}/`),
        name: post.data.title,
      })),
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: absoluteUrl("/"),
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Tags",
        item: absoluteUrl("/tags/"),
      },
      {
        "@type": "ListItem",
        position: 3,
        name: `#${tag}`,
        item: absoluteUrl(`/tags/${tag}/`),
      },
    ],
  },
];
---

<BaseLayout title={`#${tag} — Knit with Andrew`} description={`Posts tagged ${tag} on Knit with Andrew.`} structuredData={structuredData}>
  <section class="mx-auto max-w-6xl px-5 py-12">
    <a href="/tags/" class="text-sm font-black uppercase tracking-[0.2em] text-voltage-inverse">← Tags</a>
    <h1 class="mt-6 text-6xl font-black tracking-tight text-ink">#{tag}</h1>
    <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {posts.map((post: any) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>
