---
import { getCollection } from "astro:content";
import InstagramCTA from "@/components/InstagramCTA.astro";
import NewsletterCTA from "@/components/NewsletterCTA.astro";
import PostCard from "@/components/PostCard.astro";
import InternalLinkCard from "@/components/seo/InternalLinkCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { absoluteUrl } from "@/utils/seo";

const guides = (await getCollection("blog"))
  .filter((post) => !post.data.draft && post.data.type === "guide")
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Guides",
  description: "Knitting guides and practical fibre-craft explainers from Andrew.",
  url: absoluteUrl("/guides/"),
  mainEntity: {
    "@type": "ItemList",
    itemListElement: guides.map((post, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: absoluteUrl(`/blog/${post.id}/`),
      name: post.data.title,
    })),
  },
};
const relatedSections = [
  {
    href: "/pattern-testing/",
    label: "Pattern testing advice",
    description: "If you are here for test knitting and designer workflow, the pattern testing section is the direct route.",
  },
  {
    href: "/blog/",
    label: "Knitting blog posts",
    description: "The blog holds project notes, design experiments, and the messier diary side of making things.",
  },
  {
    href: "/patterns/",
    label: "Knitting pattern notes",
    description: "Pattern pages collect design diaries, yarn choices, and the work behind the finished object.",
  },
];
---

<BaseLayout title="Knitting Guides — Knit with Andrew" description="Knitting guides, pattern testing explainers, and practical fibre-craft advice from Andrew." structuredData={structuredData}>
  <section class="mx-auto max-w-6xl px-5 py-12">
    <p class="text-sm font-black uppercase tracking-[0.25em] text-voltage">Learn</p>
    <h1 class="mt-4 text-6xl font-black tracking-tight text-ink">Knitting guides</h1>
    <p class="mt-5 max-w-2xl text-xl font-semibold leading-8 text-ink-soft">A home for useful knitting notes, pattern testing explainers, and approachable knitting technique guides.</p>

    {guides.length > 0 ? (
      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {guides.map((post) => <PostCard post={post} />)}
      </div>
    ) : (
      <div class="mt-10 rounded-4xl border-2 border-ink bg-paper/70 p-6 text-lg font-semibold leading-8 text-ink-soft">
        More knitting guides are on the way. For now, the blog and pattern testing pages have the freshest notes.
      </div>
    )}

    <div class="mt-12 grid gap-5 md:grid-cols-3">
      {relatedSections.map((card) => <InternalLinkCard {...card} />)}
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-2">
      <InstagramCTA title="Follow guide-sized progress on Instagram" eventLocation="guides_index_cta" />
      <NewsletterCTA eventLocation="guides_index_cta" />
    </div>
  </section>
</BaseLayout>