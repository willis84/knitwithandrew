---
import { getCollection } from "astro:content";
import InstagramCTA from "@/components/InstagramCTA.astro";
import NewsletterCTA from "@/components/NewsletterCTA.astro";
import PostCard from "@/components/PostCard.astro";
import InternalLinkCard from "@/components/seo/InternalLinkCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { absoluteUrl } from "@/utils/seo";

const patterns = (await getCollection("blog"))
  .filter((post) => !post.data.draft && post.data.type === "pattern")
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Knitting patterns",
  description: "Knitting pattern notes, design diaries, project details, and Ravelry links from Andrew Willis.",
  url: absoluteUrl("/patterns/"),
  mainEntity: {
    "@type": "ItemList",
    itemListElement: patterns.map((post, index) => ({
      "@type": "ListItem",
      position: index + 1,
      url: absoluteUrl(`/blog/${post.id}/`),
      name: post.data.title,
    })),
  },
};

const relatedSections = [
  {
    href: "/blog/",
    label: "Read the knitting blog",
    description: "Project notes and design rambles live on the blog while the pattern pages are still growing.",
  },
  {
    href: "/guides/",
    label: "Browse knitting tutorials",
    description: "If you want practical help right now, the guides section is the quickest route.",
  },
  {
    href: "/about/",
    label: "Read more about Andrew",
    description: "The about page has the personal side of the site and the best places to follow the work while patterns are still taking shape.",
  },
];
---

<BaseLayout title="Knitting Patterns — Knit with Andrew" description="Knitting pattern notes, design diaries, project details, and Ravelry links from Andrew Willis." structuredData={structuredData}>
  <section class="mx-auto max-w-6xl px-5 py-12">
    <p class="text-sm font-black uppercase tracking-[0.25em] text-candy-paint">Design</p>
    <h1 class="mt-4 text-6xl font-black tracking-tight text-ink">Knitting patterns</h1>
    <p class="mt-5 max-w-2xl text-xl font-semibold leading-8 text-ink-soft">Pattern notes, design diaries, and the projects that are inching towards a proper release.</p>

    {patterns.length > 0 ? (
      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {patterns.map((post) => <PostCard post={post} />)}
      </div>
    ) : (
      <div class="mt-10 rounded-[2rem] border-2 border-ink bg-paper/70 p-6 shadow-sm">
        <p class="text-lg font-semibold leading-8 text-ink-soft">Pattern pages are coming soon. For now, follow along on Instagram for project notes, tester calls, and work-in-progress updates.</p>
      </div>
    )}
  </section>

  <section class="mx-auto max-w-6xl px-5 py-10">
    <div class="grid gap-5 md:grid-cols-3">
      {relatedSections.map((card) => (
        <InternalLinkCard
          href={card.href}
          label={card.label}
          description={card.description}
        />
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-4">
    <div class="grid gap-6 lg:grid-cols-2">
      <InstagramCTA title="Follow the pattern experiments on Instagram" />
      <NewsletterCTA />
    </div>
  </section>
</BaseLayout>
