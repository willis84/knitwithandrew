---
import type { SocialIconName } from "@/data/site";

interface Props {
  name: SocialIconName;
  class?: string;
}

const { name, class: className = "size-5" } = Astro.props;
---

{
  name === "instagram" && (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class={className}
      aria-hidden="true"
      focusable="false"
    >
      <rect x="3" y="3" width="18" height="18" rx="5"></rect>
      <circle cx="12" cy="12" r="4"></circle>
      <circle cx="17.5" cy="6.5" r="1"></circle>
    </svg>
  )
}

