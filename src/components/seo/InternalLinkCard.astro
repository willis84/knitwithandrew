---
interface Props {
  href: string;
  label: string;
  description: string;
}

const { href, label, description } = Astro.props;
---

<a href={href} class="block rounded-[1.7rem] border-2 border-ink bg-paper/70 p-5 shadow-sm transition hover:-translate-y-1 hover:bg-panel hover:text-panel-text">
  <h3 class="text-xl font-black tracking-tight">{label}</h3>
  <p class="mt-3 text-sm font-semibold leading-6 text-ink-soft [a:hover_&]:text-panel-text">{description}</p>
</a>
