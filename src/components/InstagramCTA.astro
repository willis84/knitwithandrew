---
import { site } from "@/data/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Follow my latest knitting projects on Instagram",
  description = "Follow my latest knitting projects, tester calls, and colourful experiments on Instagram.",
} = Astro.props;
---

<section class="rounded-[2rem] border-2 border-ink bg-panel p-6 text-panel-text shadow-[10px_10px_0_color-mix(in_oklch,var(--color-candy-paint)_40%,transparent)] sm:p-8">
  <p class="text-sm font-black uppercase tracking-[0.25em] text-panel-text/70">Instagram</p>
  <h2 class="mt-3 text-3xl font-black tracking-tight sm:text-4xl">{title}</h2>
  <p class="mt-4 max-w-2xl text-base font-semibold leading-7 text-panel-text/85">{description}</p>
  <a
    data-cta="instagram-follow"
    href={site.socials.instagram}
    target="_blank"
    rel="noopener noreferrer"
    class="mt-6 inline-flex rounded-full bg-paper px-6 py-3 text-sm font-black text-ink transition hover:-translate-y-0.5"
  >
    Follow on Instagram
  </a>
</section>
