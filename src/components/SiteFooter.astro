---
import SocialLinks from "@/components/SocialLinks.astro";
import { site } from "@/data/site";
---

<footer class="mx-auto mt-20 w-full max-w-6xl px-5 pb-10">
  <div class="rounded-[2rem] border-2 border-ink bg-panel p-6 text-panel-text shadow-[10px_10px_0_color-mix(in_oklch,var(--color-candy-paint)_45%,transparent)]">
    <div class="flex flex-col justify-between gap-6 sm:flex-row sm:items-end">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.25em] text-panel-text/60">{site.domain}</p>
        <p class="mt-3 max-w-xl text-sm font-semibold leading-6 text-panel-text/80">
          A colourful knitting home for project notes, guides, design experiments, and the messy useful bits of pattern testing.
        </p>
      </div>
      <SocialLinks compact />
    </div>
  </div>
</footer>
