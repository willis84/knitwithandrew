---
import { site } from "@/data/site";

const nav = [
  { label: "Home", href: "/" },
  { label: "Blog", href: "/blog/" },
  { label: "Guides", href: "/guides/" },
  { label: "Patterns", href: "/patterns/" },
  { label: "About", href: "/about/" },
];
---

<header class="sticky top-0 z-40 border-b border-ink/10 bg-paper/80 backdrop-blur">
  <div class="relative mx-auto w-full max-w-6xl px-5 py-4 md:py-6">
    <div class="grid grid-cols-2 items-center gap-3 md:flex md:justify-between md:gap-4">
    <a href="/" class="group inline-flex items-center gap-3 font-black tracking-tight text-ink no-underline">
      <span class="grid size-11 place-items-center rounded-2xl bg-panel text-xl text-panel-text shadow-[6px_6px_0_var(--color-candy-paint)] transition group-hover:-translate-y-0.5">A</span>
      <span class="text-lg sm:text-xl">{site.name}</span>
    </a>

    <nav class="hidden items-center gap-2 rounded-full border-2 border-ink/10 bg-paper/55 p-1 shadow-sm backdrop-blur md:flex">
      {nav.map((item) => (
        <a
          href={item.href}
          class="rounded-full px-3 py-2 text-sm font-extrabold text-ink-soft transition hover:bg-panel hover:text-panel-text sm:px-4"
        >
          {item.label}
        </a>
      ))}
    </nav>
    
    <details class="group justify-self-end md:hidden">
      <summary class="flex cursor-pointer list-none items-center justify-center gap-3 rounded-[1.5rem] border-2 border-ink/10 bg-paper/70 px-5 py-4 text-sm font-black uppercase tracking-[0.2em] text-ink shadow-sm marker:hidden [&::-webkit-details-marker]:hidden">
        <span class="text-base leading-none text-candy-paint">☰</span>
        <span>Menu</span>
      </summary>
      <nav class="absolute left-5 right-5 top-full mt-3 grid gap-2 rounded-[1.75rem] border-2 border-ink/10 bg-paper/95 p-3 shadow-[10px_10px_0_color-mix(in_oklch,var(--color-candy-paint)_22%,transparent)] backdrop-blur">
        {nav.map((item) => (
          <a
            href={item.href}
            class="rounded-[1.2rem] px-4 py-3 text-center text-sm font-extrabold text-ink-soft transition hover:bg-panel hover:text-panel-text"
          >
            {item.label}
          </a>
        ))}
      </nav>
    </details>
    </div>

  </div>
</header>
