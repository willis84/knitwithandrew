---
import SocialIcon from "@/components/SocialIcon.astro";
import { links } from "@/data/site";

interface Props {
  compact?: boolean;
  className?: string;
  desktopColumns?: 2 | 4;
  eventLocation?: string;
}

const { compact = false, className = "", desktopColumns = 4, eventLocation = "unknown" } = Astro.props;

const standardGridClass = desktopColumns === 2
  ? "grid gap-4 sm:grid-cols-2 lg:grid-cols-2"
  : "grid gap-4 sm:grid-cols-2 lg:grid-cols-4";
---

<div
  class:list={[
    compact
      ? "grid grid-cols-2 justify-items-center gap-3 lg:justify-items-end"
      : standardGridClass,
    className,
  ]}
>
  {links.map((link) => (
    <a
      href={link.href}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`${link.label} profile`}
      data-simple-event={`${link.label.toLowerCase().replace(/[^a-z0-9]+/g, "_").replace(/^_|_$/g, "")}_click`}
      data-simple-event-location={eventLocation}
      class:list={[
        compact
          ? "inline-flex w-full max-w-[10rem] items-center justify-center gap-2 rounded-full border border-panel-text/20 px-4 py-2 text-sm font-extrabold text-inherit transition hover:bg-paper hover:text-ink lg:justify-self-end"
          : "group block rounded-[1.7rem] border-2 border-ink bg-paper/75 p-5 text-ink shadow-[7px_7px_0_rgba(16,16,20,0.16)] transition hover:-translate-y-1 hover:shadow-[10px_10px_0_color-mix(in_oklch,var(--color-candy-paint)_38%,transparent)]",
      ]}
    >
      {compact ? (
        <>
          <SocialIcon name={link.icon} class="size-4" />
          <span>{link.label}</span>
        </>
      ) : (
        <>
          <span class="flex items-center justify-between gap-4">
            <span class="text-xl font-black tracking-tight">{link.label}</span>
            <span class="grid size-9 place-items-center rounded-full bg-panel text-panel-text transition group-hover:bg-candy-paint">
              <SocialIcon name={link.icon} class="size-4.5" />
            </span>
          </span>
          <span class="mt-3 block text-sm font-semibold leading-6 text-ink-soft">{link.description}</span>
        </>
      )}
    </a>
  ))}
</div>
