---
import { comments } from "@/data/site";

interface Props {
  term: string;
}

const { term } = Astro.props;
---

{comments.enabled ? (
  <section class="mt-14 rounded-4xl border-2 border-ink/10 bg-paper/65 p-6">
    <h2 class="text-2xl font-black tracking-tight text-ink">Comments</h2>
    <div class="mt-5">
      <script
        is:inline
        src="https://giscus.app/client.js"
        data-repo={comments.repo}
        data-repo-id={comments.repoId}
        data-category={comments.category}
        data-category-id={comments.categoryId}
        data-mapping="specific"
        data-term={term}
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="top"
        data-theme="preferred_color_scheme"
        data-lang="en"
        crossorigin="anonymous"
        async
      ></script>
    </div>
  </section>
) : (
  <section class="mt-14 rounded-4xl border-2 border-dashed border-ink/20 bg-paper/45 p-6">
    <h2 class="text-2xl font-black tracking-tight text-ink">Comments later</h2>
    <p class="mt-3 max-w-2xl font-semibold leading-7 text-ink-soft">
      This site is static, so comments are best added with Giscus, Utterances, Hyvor Talk, or another hosted/static-friendly comment tool.
      Giscus support is already wired in <code>src/data/site.ts</code>; flip <code>enabled</code> once you have repo IDs.
    </p>
  </section>
)}
